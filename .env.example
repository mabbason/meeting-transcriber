# Meeting Transcriber Configuration

# Whisper model size: tiny, base, small, medium, large-v3
# medium recommended for GTX 1080 (8GB VRAM)
WHISPER_MODEL=medium

# Device: cuda or cpu
WHISPER_DEVICE=cuda

# Compute type: float16 (Ampere+), int8_float32 (older GPUs like GTX 1080), int8 (CPU)
WHISPER_COMPUTE_TYPE=int8_float32

# Audio chunk size in seconds (lower = less latency, but less context for accuracy)
AUDIO_CHUNK_SECONDS=5

# Overlap between chunks to avoid cutting words at boundaries
AUDIO_OVERLAP_SECONDS=0.5

# Web server port
WEB_PORT=8765

# Session storage directory
SESSIONS_DIR=./sessions

# HuggingFace token (required for pyannote speaker diarization)
# Get one at https://huggingface.co/settings/tokens
# Then accept terms at https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=
